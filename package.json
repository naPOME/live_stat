{
  "name": "live-stat-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:local": "npm -w live-stat-local run dev",
    "dev:cloud": "npm -w cloud run dev",
    "electron:dev": "npm -w live-stat-local run electron:dev",
    "electron:build": "npm -w live-stat-local run electron:build",
    "build": "turbo build",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
