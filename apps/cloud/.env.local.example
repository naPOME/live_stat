# Supabase — get from: Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# "anon" public key (safe to expose) — labeled "Publishable" or "anon" in dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key-here

# "service_role" SECRET key — starts with eyJ..., NOT sb_publishable_...
# Location: Dashboard → Settings → API → "service_role" → Reveal → copy the long eyJ... JWT
# ⚠️  Never put this in client code. Used for /api/match-results and /api/export only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key-here
